{
    "name": "geodineum/gtemplate-wp",
    "description": "Geodineum parent theme for WordPress — gCore framework integration",
    "type": "wordpress-theme",
    "license": "(MIT OR Apache-2.0)",
    "require": {
        "php": ">=7.4",
        "composer/installers": "~1.0",
        "geodineum/gcore": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
