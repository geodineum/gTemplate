{
    "name": "geodineum/gtemplate-wp",
    "description": "Geodineum parent theme for WordPress — gCore framework integration",
    "type": "wordpress-theme",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "/opt/geodineum/gCore",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/opt/geodineum/gNode-Client"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "~1.0",
        "geodineum/gcore": "*"
    },
    "autoload": {
        "psr-4": {
            "gTemplate\\": "core/",
            "gTemplate\\Modules\\": "modules/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
